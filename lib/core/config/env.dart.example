/// API keys for external services.
///
/// Copy this file to `env.dart` and fill in your own keys.
/// NEVER commit `env.dart` to version control — it is .gitignored.
///
/// Keys are injected at build time via `--dart-define`:
///   flutter build apk --dart-define=OPENROUTER_API_KEY=sk-or-... \
///                      --dart-define=GOOGLE_AI_API_KEY=AIza...
///
/// When no key is provided, AI features are gracefully disabled.
abstract final class Env {
  /// OpenRouter API key (SMS enrichment, AI chat).
  static const String openRouterApiKey =
      String.fromEnvironment('OPENROUTER_API_KEY');

  /// Google AI Studio API key (Gemini — voice audio transcription + parsing).
  static const String googleAiApiKey =
      String.fromEnvironment('GOOGLE_AI_API_KEY');
}
