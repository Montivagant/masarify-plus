<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) backup opt-out.

  Excludes ALL domains from both cloud backup (Google Drive auto backup) and
  device-to-device transfer. Combined with `android:allowBackup="false"` in
  AndroidManifest.xml, this prevents Android from silently restoring the
  Drift database on reinstall / after "Clear Data" — previously this caused
  deleted subscriptions to reappear because Google Drive was restoring the
  old DB behind the user's back.

  If you ever want to re-enable backups, remove both `exclude` elements and
  replace with `<include domain="file" path="backup_me.db" />` or similar
  targeted rules.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
